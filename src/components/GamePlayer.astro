---
interface Props {
  title: string;
  embedUrl: string;
  thumbnailSrc: string;
  thumbnailWidth: number;
  thumbnailHeight: number;
  orientation: 'landscape' | 'portrait' | 'both';
}

const { title, embedUrl, thumbnailSrc, thumbnailWidth, thumbnailHeight, orientation } = Astro.props;
---
<div
  class="game-player"
  data-embed-url={embedUrl}
  data-orientation={orientation}
>
  <div class="game-player__poster">
    <img
      class="game-player__poster-img"
      src={thumbnailSrc}
      width={thumbnailWidth}
      height={thumbnailHeight}
      alt={`${title} — press play to start`}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <button type="button" class="game-player__play" aria-label={`Play ${title}`}>
      <span aria-hidden="true" class="game-player__play-icon">▶</span>
      Play
    </button>
  </div>

  <!-- Loading overlay -->
  <div class="game-player__loading" aria-hidden="true">
    <div class="game-player__spinner"></div>
    <span>Loading game…</span>
  </div>

  <!-- Fullscreen button (shown once game is active) -->
  <button type="button" class="game-player__fs" aria-label="Enter fullscreen" hidden>
    <svg class="icon-expand" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
      <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
      <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
    </svg>
    <svg class="icon-compress" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- Rotate-device hint (landscape games on portrait touchscreens) — dismissible banner, non-blocking -->
  <div class="game-player__rotate-hint" role="status" aria-live="polite" hidden>
    <svg class="game-player__rotate-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="5" y="2" width="14" height="20" rx="2"/>
      <path d="M9 18h6"/>
    </svg>
    <span>Rotate for a better view</span>
    <button type="button" class="game-player__rotate-dismiss" aria-label="Dismiss rotate hint">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Error overlay -->
  <div class="game-player__error" role="alert" aria-live="polite">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <p class="game-player__error-msg">This game couldn't load.</p>
    <p class="game-player__error-sub">Your network may be blocking the game provider. Try a different network, or open the game directly.</p>
    <div class="game-player__error-actions">
      <button type="button" class="game-player__retry">Try again</button>
      <a class="game-player__open-tab" href="#" target="_blank" rel="noopener noreferrer">Open in new tab ↗</a>
    </div>
  </div>
</div>

<style>
  .game-player {
    position: relative;
    width: 100%;
    background: #000;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .game-player[data-orientation='portrait'] { aspect-ratio: 9 / 16; max-width: 24rem; margin: 0 auto; }

  .game-player__poster,
  .game-player__poster-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .game-player__play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    padding: var(--space-3) var(--space-6);
    background: rgba(255,255,255,0.95);
    border: none;
    border-radius: 999px;
    font-weight: 700;
    font-size: var(--fs-lg);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .game-player__play:hover,
  .game-player__play:focus { background: #fff; }

  /* Fullscreen button — top-right so it's never hidden by mobile browser chrome */
  .game-player__fs {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    color: #fff;
    cursor: pointer;
    transition: background 0.15s, opacity 0.2s, transform 0.15s;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    -webkit-tap-highlight-color: transparent;
  }
  .game-player__fs:hover,
  .game-player__fs:focus-visible { background: rgba(0, 0, 0, 0.85); }
  .game-player__fs:active { transform: scale(0.94); }

  /* Desktop: reveal on hover to keep the frame clean */
  @media (hover: hover) and (pointer: fine) {
    .game-player__fs { opacity: 0; }
    .game-player:hover .game-player__fs,
    .game-player:focus-within .game-player__fs,
    .game-player.is-fullscreen .game-player__fs { opacity: 1; }
  }

  .game-player__fs .icon-compress { display: none; }
  .game-player.is-fullscreen .game-player__fs .icon-expand   { display: none; }
  .game-player.is-fullscreen .game-player__fs .icon-compress { display: block; }

  /* CSS fullscreen overlay — primary path for iOS (native FS on elements is unsupported) */
  .game-player.is-fullscreen {
    position: fixed;
    inset: 0;
    z-index: 9998;
    width: 100vw;
    width: 100dvw;
    height: 100vh;
    height: 100dvh;
    max-width: none;
    aspect-ratio: unset;
    border-radius: 0;
    margin: 0;
  }

  /* Safe-area insets inside fullscreen so the exit button clears the notch/dynamic island */
  .game-player.is-fullscreen .game-player__fs {
    top: calc(var(--space-3) + env(safe-area-inset-top, 0px));
    right: calc(var(--space-3) + env(safe-area-inset-right, 0px));
    width: 48px;
    height: 48px;
  }

  /* Native browser fullscreen (desktop enhancement) */
  .game-player:fullscreen,
  .game-player:-webkit-full-screen {
    width: 100vw;
    height: 100vh;
    max-width: none;
    aspect-ratio: unset;
    border-radius: 0;
  }

  /* Rotate-device hint — small non-blocking banner at top center; dismissible */
  .game-player__rotate-hint {
    position: absolute;
    top: calc(var(--space-3) + env(safe-area-inset-top, 0px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 11;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    max-width: calc(100% - 6rem);
    padding: 8px 10px 8px 14px;
    background: rgba(0, 0, 0, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    color: #fff;
    font-size: var(--fs-xs, 13px);
    font-weight: 600;
    line-height: 1.2;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    animation: rotate-hint-in 220ms ease-out both;
  }
  .game-player__rotate-hint[hidden] { display: none; }

  .game-player__rotate-icon {
    flex-shrink: 0;
    animation: rotate-hint-wobble 2s ease-in-out infinite;
    transform-origin: center;
  }
  @keyframes rotate-hint-wobble {
    0%, 45%, 100% { transform: rotate(0deg); }
    65%, 85% { transform: rotate(-90deg); }
  }
  @keyframes rotate-hint-in {
    from { opacity: 0; transform: translate(-50%, -8px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }

  .game-player__rotate-dismiss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    margin-left: var(--space-1, 4px);
    padding: 0;
    background: rgba(255, 255, 255, 0.12);
    border: 0;
    border-radius: 999px;
    color: #fff;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.15s;
  }
  .game-player__rotate-dismiss:hover,
  .game-player__rotate-dismiss:focus-visible { background: rgba(255, 255, 255, 0.24); }

  /* Loading */
  .game-player__loading {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    background: #000;
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }
  .game-player__loading.is-visible { display: flex; }

  .game-player__spinner {
    width: 36px;
    height: 36px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error */
  .game-player__error {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    background: #0c0c1a;
    color: var(--color-muted);
    padding: var(--space-8);
    text-align: center;
  }
  .game-player__error.is-visible { display: flex; }
  .game-player__error svg { opacity: 0.5; flex-shrink: 0; }

  .game-player__error-msg {
    font-weight: 700;
    font-size: var(--fs-md);
    color: var(--color-fg);
    margin: 0;
  }
  .game-player__error-sub {
    font-size: var(--fs-sm);
    max-width: 28rem;
    margin: 0;
    line-height: 1.5;
  }

  .game-player__retry {
    margin-top: var(--space-2);
    padding: var(--space-2) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-fg);
    font-size: var(--fs-sm);
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
  }
  .game-player__retry:hover { background: var(--color-card); }

  .game-player__error-actions {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-2);
  }

  .game-player__open-tab {
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--color-accent);
  }
  .game-player__open-tab:hover { opacity: 0.8; }
</style>

<script>
  const LOAD_TIMEOUT_MS = 12_000;

  const isTouch = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

  document.querySelectorAll<HTMLElement>('.game-player').forEach((root) => {
    const playBtn   = root.querySelector<HTMLButtonElement>('.game-player__play');
    const poster    = root.querySelector<HTMLElement>('.game-player__poster');
    const loading   = root.querySelector<HTMLElement>('.game-player__loading');
    const errorEl   = root.querySelector<HTMLElement>('.game-player__error');
    const retryBtn  = root.querySelector<HTMLButtonElement>('.game-player__retry');
    const openTab   = root.querySelector<HTMLAnchorElement>('.game-player__open-tab');
    const fsBtn     = root.querySelector<HTMLButtonElement>('.game-player__fs');
    const rotateHint   = root.querySelector<HTMLElement>('.game-player__rotate-hint');
    const rotateDismiss = root.querySelector<HTMLButtonElement>('.game-player__rotate-dismiss');
    const embedUrl  = root.dataset.embedUrl;
    const orientation = root.dataset.orientation ?? 'both';
    if (!playBtn || !poster || !embedUrl) return;

    // Re-assert as non-nullable so closures below satisfy TS
    const safeEmbedUrl: string = embedUrl;
    const safePoster: HTMLElement = poster;

    if (openTab) openTab.href = safeEmbedUrl;

    let timer: ReturnType<typeof setTimeout>;
    let iframe: HTMLIFrameElement | null = null;

    function showError() {
      clearTimeout(timer);
      iframe?.remove();
      loading?.classList.remove('is-visible');
      errorEl?.classList.add('is-visible');
    }

    let rotateHintTimer: ReturnType<typeof setTimeout> | undefined;
    let rotateHintDismissed = false;

    function updateRotateHint() {
      if (!rotateHint) return;
      const inFs = root.classList.contains('is-fullscreen');
      const portrait = window.matchMedia('(orientation: portrait)').matches;
      const shouldShow =
        inFs && isTouch && orientation === 'landscape' && portrait && !rotateHintDismissed;
      rotateHint.hidden = !shouldShow;

      // Auto-dismiss after 6s so it never feels sticky.
      clearTimeout(rotateHintTimer);
      if (shouldShow) {
        rotateHintTimer = setTimeout(() => {
          if (rotateHint) rotateHint.hidden = true;
        }, 6000);
      }
    }

    rotateDismiss?.addEventListener('click', (e) => {
      e.stopPropagation();
      rotateHintDismissed = true;
      if (rotateHint) rotateHint.hidden = true;
      clearTimeout(rotateHintTimer);
    });

    // iOS Safari: nudge the URL bar into its minimized state when going "fullscreen".
    // Works best when the page has some scroll height; harmless otherwise.
    function nudgeUrlBar() {
      if (!isTouch) return;
      try {
        const y = window.scrollY;
        window.scrollTo(0, Math.max(y, 1));
      } catch { /* ignore */ }
    }

    function enterFullscreen() {
      // Ensure the exit button is reachable — iframe `load` may fire after FS is active.
      if (fsBtn) fsBtn.hidden = false;

      // Native fullscreen (desktop / Android Chrome); iOS Safari doesn't support it on arbitrary elements.
      const req =
        (root as any).requestFullscreen?.bind(root) ??
        (root as any).webkitRequestFullscreen?.bind(root);

      const nativeResult: Promise<void> | undefined = req ? req() : undefined;

      const applyCss = () => {
        nudgeUrlBar();
        setCssFs(true);
      };

      if (nativeResult && typeof nativeResult.then === 'function') {
        nativeResult.then(applyCss).catch(applyCss);
      } else {
        applyCss();
      }

      // Best-effort orientation lock for landscape games — only works inside a fullscreen context.
      if (orientation === 'landscape') {
        const orient = (screen as any).orientation;
        try {
          orient?.lock?.('landscape')?.catch?.(() => { /* unsupported */ });
        } catch { /* unsupported */ }
      }
    }

    function exitFullscreen() {
      const doc = document as any;
      const nativeFs = doc.fullscreenElement || doc.webkitFullscreenElement;
      const exitFn: (() => Promise<void>) | undefined =
        doc.exitFullscreen?.bind(document) ?? doc.webkitExitFullscreen?.bind(document);

      try { (screen as any).orientation?.unlock?.(); } catch { /* unsupported */ }

      if (nativeFs && exitFn) {
        const ex = exitFn();
        if (ex && typeof ex.then === 'function') {
          ex.catch(() => { /* ignore */ }).finally(() => setCssFs(false));
          return;
        }
      }
      setCssFs(false);
    }

    function launchGame() {
      errorEl?.classList.remove('is-visible');
      loading?.classList.add('is-visible');
      safePoster.style.display = 'none';

      iframe = document.createElement('iframe');
      iframe.src = safeEmbedUrl;
      iframe.allow = 'autoplay; fullscreen';
      iframe.referrerPolicy = 'no-referrer';
      iframe.loading = 'eager';
      iframe.title = 'Game';
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;display:none';

      timer = setTimeout(showError, LOAD_TIMEOUT_MS);

      iframe.addEventListener('load', () => {
        clearTimeout(timer);
        loading?.classList.remove('is-visible');
        if (iframe) iframe.style.display = '';
        if (fsBtn) fsBtn.hidden = false;
      });

      iframe.addEventListener('error', showError);

      root.appendChild(iframe);

      // Mobile: auto-enter fullscreen — matches player convention on touch game portals.
      // Still the same user gesture (Play tap), so native FS requests remain valid.
      if (isTouch) {
        enterFullscreen();
      } else {
        // Desktop: collapse any sticky headers and bring the player into view.
        root.scrollIntoView({ block: 'start', behavior: 'smooth' });
      }
    }

    playBtn.addEventListener('click', launchGame);

    retryBtn?.addEventListener('click', () => {
      safePoster.style.display = '';
      errorEl?.classList.remove('is-visible');
      if (fsBtn) fsBtn.hidden = true;
    });

    function setCssFs(on: boolean) {
      root.classList.toggle('is-fullscreen', on);
      document.body.style.overflow = on ? 'hidden' : '';
      if (fsBtn) fsBtn.setAttribute('aria-label', on ? 'Exit fullscreen' : 'Enter fullscreen');
      if (!on) {
        rotateHintDismissed = false;
        if (rotateHint) rotateHint.hidden = true;
        clearTimeout(rotateHintTimer);
      } else {
        updateRotateHint();
      }
    }

    // Re-evaluate hint visibility on orientation changes (rotating to landscape hides it).
    window.matchMedia('(orientation: portrait)').addEventListener?.('change', updateRotateHint);

    fsBtn?.addEventListener('click', () => {
      if (root.classList.contains('is-fullscreen')) {
        exitFullscreen();
      } else {
        enterFullscreen();
      }
    });

    // Sync state when native fullscreen exits (Esc key, system gesture).
    function onFsChange() {
      const doc = document as any;
      const nativeFs = doc.fullscreenElement === root || doc.webkitFullscreenElement === root;
      if (!nativeFs && root.classList.contains('is-fullscreen') &&
          !doc.fullscreenElement && !doc.webkitFullscreenElement) {
        setCssFs(false);
      }
    }
    document.addEventListener('fullscreenchange', onFsChange);
    document.addEventListener('webkitfullscreenchange', onFsChange);

    // Esc key exits CSS-overlay fullscreen (native FS handles this itself).
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && root.classList.contains('is-fullscreen') &&
          !(document as any).fullscreenElement && !(document as any).webkitFullscreenElement) {
        exitFullscreen();
      }
    });
  });
</script>
