---
interface Props {
  title: string;
  embedUrl: string;
  thumbnailSrc: string;
  thumbnailWidth: number;
  thumbnailHeight: number;
  orientation: 'landscape' | 'portrait' | 'both';
}

const { title, embedUrl, thumbnailSrc, thumbnailWidth, thumbnailHeight, orientation } = Astro.props;
---
<div
  class="game-player"
  data-embed-url={embedUrl}
  data-orientation={orientation}
>
  <div class="game-player__poster">
    <img
      class="game-player__poster-img"
      src={thumbnailSrc}
      width={thumbnailWidth}
      height={thumbnailHeight}
      alt={`${title} — press play to start`}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <button type="button" class="game-player__play" aria-label={`Play ${title}`}>
      <span aria-hidden="true" class="game-player__play-icon">▶</span>
      Play
    </button>
  </div>

  <!-- Loading overlay -->
  <div class="game-player__loading" aria-hidden="true">
    <div class="game-player__spinner"></div>
    <span>Loading game…</span>
  </div>

  <!-- Fullscreen button (shown once game is active) -->
  <button type="button" class="game-player__fs" aria-label="Toggle fullscreen" hidden>
    <svg class="icon-expand" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
      <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
      <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
    </svg>
    <svg class="icon-compress" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
      <polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/>
      <line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/>
    </svg>
  </button>

  <!-- Error overlay -->
  <div class="game-player__error" role="alert" aria-live="polite">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <p class="game-player__error-msg">This game couldn't load.</p>
    <p class="game-player__error-sub">Your network may be blocking the game provider. Try a different network, or open the game directly.</p>
    <div class="game-player__error-actions">
      <button type="button" class="game-player__retry">Try again</button>
      <a class="game-player__open-tab" href="#" target="_blank" rel="noopener noreferrer">Open in new tab ↗</a>
    </div>
  </div>
</div>

<style>
  .game-player {
    position: relative;
    width: 100%;
    background: #000;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .game-player[data-orientation='portrait'] { aspect-ratio: 9 / 16; max-width: 24rem; margin: 0 auto; }

  .game-player__poster,
  .game-player__poster-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .game-player__play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    padding: var(--space-3) var(--space-6);
    background: rgba(255,255,255,0.95);
    border: none;
    border-radius: 999px;
    font-weight: 700;
    font-size: var(--fs-lg);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .game-player__play:hover,
  .game-player__play:focus { background: #fff; }

  /* Fullscreen button */
  .game-player__fs {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md);
    color: #fff;
    cursor: pointer;
    transition: background 0.15s, opacity 0.2s;
    backdrop-filter: blur(4px);
  }
  .game-player__fs:hover { background: rgba(0, 0, 0, 0.85); }

  /* Hide on desktop until hover; always show on touch devices */
  @media (hover: hover) {
    .game-player__fs { opacity: 0; }
    .game-player:hover .game-player__fs,
    .game-player:focus-within .game-player__fs { opacity: 1; }
  }

  .game-player__fs .icon-compress { display: none; }
  .game-player.is-fullscreen .game-player__fs .icon-expand   { display: none; }
  .game-player.is-fullscreen .game-player__fs .icon-compress { display: block; }

  /* Fullscreen: fill the viewport regardless of aspect-ratio */
  .game-player:fullscreen,
  .game-player:-webkit-full-screen {
    width: 100vw;
    height: 100vh;
    max-width: none;
    aspect-ratio: unset;
    border-radius: 0;
  }

  /* Loading */
  .game-player__loading {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    background: #000;
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }
  .game-player__loading.is-visible { display: flex; }

  .game-player__spinner {
    width: 36px;
    height: 36px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Error */
  .game-player__error {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    background: #0c0c1a;
    color: var(--color-muted);
    padding: var(--space-8);
    text-align: center;
  }
  .game-player__error.is-visible { display: flex; }
  .game-player__error svg { opacity: 0.5; flex-shrink: 0; }

  .game-player__error-msg {
    font-weight: 700;
    font-size: var(--fs-md);
    color: var(--color-fg);
    margin: 0;
  }
  .game-player__error-sub {
    font-size: var(--fs-sm);
    max-width: 28rem;
    margin: 0;
    line-height: 1.5;
  }

  .game-player__retry {
    margin-top: var(--space-2);
    padding: var(--space-2) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-fg);
    font-size: var(--fs-sm);
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
  }
  .game-player__retry:hover { background: var(--color-card); }

  .game-player__error-actions {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-2);
  }

  .game-player__open-tab {
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--color-accent);
  }
  .game-player__open-tab:hover { opacity: 0.8; }
</style>

<script>
  const LOAD_TIMEOUT_MS = 12_000;

  document.querySelectorAll<HTMLElement>('.game-player').forEach((root) => {
    const playBtn   = root.querySelector<HTMLButtonElement>('.game-player__play');
    const poster    = root.querySelector<HTMLElement>('.game-player__poster');
    const loading   = root.querySelector<HTMLElement>('.game-player__loading');
    const errorEl   = root.querySelector<HTMLElement>('.game-player__error');
    const retryBtn  = root.querySelector<HTMLButtonElement>('.game-player__retry');
    const openTab   = root.querySelector<HTMLAnchorElement>('.game-player__open-tab');
    const fsBtn     = root.querySelector<HTMLButtonElement>('.game-player__fs');
    const embedUrl  = root.dataset.embedUrl;
    if (!playBtn || !poster || !embedUrl) return;

    // Re-assert as non-nullable so closures below satisfy TS
    const safeEmbedUrl: string = embedUrl;
    const safePoster: HTMLElement = poster;

    if (openTab) openTab.href = safeEmbedUrl;

    let timer: ReturnType<typeof setTimeout>;
    let iframe: HTMLIFrameElement | null = null;

    function showError() {
      clearTimeout(timer);
      iframe?.remove();
      loading?.classList.remove('is-visible');
      errorEl?.classList.add('is-visible');
    }

    function launchGame() {
      errorEl?.classList.remove('is-visible');
      loading?.classList.add('is-visible');
      safePoster.style.display = 'none';

      iframe = document.createElement('iframe');
      iframe.src = safeEmbedUrl;
      iframe.allow = 'autoplay; fullscreen';
      iframe.referrerPolicy = 'no-referrer';
      iframe.loading = 'eager';
      iframe.title = 'Game';
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;display:none';

      timer = setTimeout(showError, LOAD_TIMEOUT_MS);

      iframe.addEventListener('load', () => {
        clearTimeout(timer);
        loading?.classList.remove('is-visible');
        if (iframe) iframe.style.display = '';
        if (fsBtn) fsBtn.hidden = false;
      });

      iframe.addEventListener('error', showError);

      root.appendChild(iframe);
    }

    playBtn.addEventListener('click', launchGame);

    retryBtn?.addEventListener('click', () => {
      safePoster.style.display = '';
      errorEl?.classList.remove('is-visible');
      if (fsBtn) fsBtn.hidden = true;
    });

    // Fullscreen toggle (standard + webkit for Safari)
    function enterFs() {
      if ('requestFullscreen' in root) {
        (root as HTMLElement).requestFullscreen().catch(() => {});
      } else if ('webkitRequestFullscreen' in root) {
        (root as any).webkitRequestFullscreen();
      }
    }
    function exitFs() {
      if ('exitFullscreen' in document) {
        document.exitFullscreen().catch(() => {});
      } else if ('webkitExitFullscreen' in document) {
        (document as any).webkitExitFullscreen();
      }
    }
    function isFs() {
      return document.fullscreenElement === root || (document as any).webkitFullscreenElement === root;
    }
    function onFsChange() {
      const fs = isFs();
      root.classList.toggle('is-fullscreen', fs);
      if (fsBtn) fsBtn.setAttribute('aria-label', fs ? 'Exit fullscreen' : 'Enter fullscreen');
    }

    fsBtn?.addEventListener('click', () => { isFs() ? exitFs() : enterFs(); });
    document.addEventListener('fullscreenchange', onFsChange);
    document.addEventListener('webkitfullscreenchange', onFsChange);
  });
</script>
