---
import type { GameEntry } from '../lib/games';

interface Props {
  game: GameEntry;
  eager?: boolean;
  size?: 'sm' | 'md' | 'lg';
}

const { game, eager = false, size = 'md' } = Astro.props;
const { data, slug } = game;
---
<a href={`/games/${slug}/`} class:list={['game-card', `game-card--${size}`]}>
  <div class="game-card__img">
    <img
      src={data.thumbnail.src}
      width={data.thumbnail.width}
      height={data.thumbnail.height}
      alt={data.title}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={eager ? 'high' : 'auto'}
    />
    <div class="game-card__overlay">
      <span class="game-card__title">{data.title}</span>
    </div>
  </div>
</a>

<style>
  .game-card {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    background: var(--color-card);
    flex-shrink: 0;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .game-card:hover {
    transform: translateY(-3px) scale(1.01);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
    text-decoration: none;
  }
  .game-card:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .game-card__img {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .game-card--lg .game-card__img { aspect-ratio: 4 / 3; }

  .game-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .game-card:hover .game-card__img img { transform: scale(1.05); }

  .game-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(6, 6, 18, 0.85) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: var(--space-3);
    opacity: 0;
    transition: opacity 0.18s ease;
  }
  .game-card:hover .game-card__overlay { opacity: 1; }

  .game-card__title {
    font-size: var(--fs-sm);
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Size variants */
  .game-card--sm { width: 140px; }
  .game-card--md { width: 180px; }
  .game-card--lg { width: 100%; }
</style>
