---
pagination:
  data: games
  size: 1
  alias: game
permalink: /games/{{ game.slug }}/
layout: base.njk
collapsedSidebar: true
includeShell: true
ogType: website
eleventyComputed:
  title: "{{ game.title }}"
  description: "{{ game.description }}"
  gameSlug: "{{ game.slug }}"
  ogImage: "{% if game.thumbnail %}{{ game.thumbnail }}{% endif %}"
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "VideoGame",
      "@id": "{{ env.siteUrl }}/games/{{ game.slug }}/#game",
      "name": {{ game.title | jsEscape | safe }},
      "description": {{ game.description | jsEscape | safe }},
      "url": {{ (env.siteUrl + "/games/" + game.slug + "/") | jsEscape | safe }},
      "genre": {{ game.category | capitalize | jsEscape | safe }},
      "gamePlatform": "Web browser",
      "applicationCategory": "Game",
      "operatingSystem": "Any",
      "inLanguage": "en",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "availability": "https://schema.org/OnlineOnly"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ env.siteUrl | jsEscape | safe }}
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ game.category | capitalize | jsEscape | safe }},
          "item": {{ (env.siteUrl + "/category/" + game.category + "/") | jsEscape | safe }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ game.title | jsEscape | safe }},
          "item": {{ (env.siteUrl + "/games/" + game.slug + "/") | jsEscape | safe }}
        }
      ]
    }
  ]
}
</script>

{% set related = games | reject("slug", game.slug) | selectattr("category", game.category) | list %}

<div class="game-page">
  <div class="game-area">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/">Home</a> /
      <a href="/category/{{ game.category }}/">{{ game.category | capitalize }}</a> /
      {{ game.title }}
    </div>

    <!-- Game iframe -->
    <div class="game-frame-wrap" id="game-wrap">
      <iframe
        id="game-frame"
        src="/games/{{ game.slug }}/game.html"
        title="{{ game.title }}"
        allowfullscreen
        sandbox="allow-scripts allow-popups"
      ></iframe>
      <button class="btn-fullscreen" id="fullscreen-btn">&#9974; Fullscreen</button>
    </div>

    <!-- Controls -->
    <div class="game-controls">
      <button class="btn-secondary" id="restart-btn">&#9851;&#65039; Restart</button>
      <span class="controls-hint">{{ game.controls }}</span>
    </div>

    <!-- Info -->
    <div class="game-info">
      <h1>{{ game.title }}</h1>
      <div class="meta">{{ game.category | upper }}</div>
      <div class="desc">{{ game.description }}</div>

      {% if game.howToPlay %}
      <h2 class="game-section-heading">How to Play {{ game.title }}</h2>
      <div class="game-section-body">{{ game.howToPlay | safe }}</div>
      {% endif %}

      {% if game.about %}
      <h2 class="game-section-heading">About {{ game.title }}</h2>
      <div class="game-section-body">{{ game.about | safe }}</div>
      {% endif %}
    </div>

  </div>

  <!-- Related games sidebar -->
  <aside class="game-sidebar">
    <h3>More {{ game.category }}</h3>
    <div class="related-list">
      {% for r in related | slice(0, 4) %}
      <a class="related-card" href="/games/{{ r.slug }}/">
        <span class="emoji">{{ r.emoji }}</span>
        <div>
          <div class="rtitle">{{ r.title }}</div>
          <div class="rcat">{{ r.category }}</div>
        </div>
      </a>
      {% else %}
      <p class="no-related">More games coming soon.</p>
      {% endfor %}
    </div>
  </aside>
</div>
